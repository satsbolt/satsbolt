# SatsBolt Environment Variables Template
# Copy this to .env before starting: cp .env.example .env

# --- Server Configurations ---
HOST=127.0.0.1
PORT=8080
ENV=development # Options: development, staging, production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006,* # CORS origins allowed by api-server
RUST_LOG=info,api_server=debug,core_ledger=debug,ldk_engine=debug # Log levels for Rust modules

# --- JWT Authentication ---
JWT_SECRET=super_secret_unbreakable_ledger_key_change_me_in_production
JWT_EXPIRATION_SECS=86400

# --- Database Connection (PostgreSQL) ---
# Note: Use 'localhost' if running api-server natively. Use 'postgres' if running inside docker-compose.
DATABASE_URL=postgres://satsbolt:secretpassword@localhost:5432/satsbolt_ledger
DATABASE_MAX_CONNECTIONS=10

# --- Bitcoin / Lightning configurations ---
LDK_NETWORK=regtest # Options: regtest, signet, testnet, mainnet
BITCOIN_RPC_URL=http://localhost:18443
BITCOIN_RPC_USER=satsbolt
BITCOIN_RPC_PASS=satsboltpass

# LDK persistent engine storage and network configuration
LDK_DATA_DIR=./.ldk_data
LDK_PEER_PORT=9735

# --- Telephony Gateway (Africa's Talking USSD) ---
AFRICAS_TALKING_USERNAME=sandbox
AFRICAS_TALKING_API_KEY=ats_apikey_1234567890abcdef...

# --- Swap/Off-Ramp Provider Configurations (e.g. Bitnob) ---
SWAP_PROVIDER_URL=https://api.sandbox.bitnob.co/v1
SWAP_PROVIDER_API_KEY=bn_apikey_abcdef123456...
